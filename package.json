{
  "name": "ouishare",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "simulate": "EXPO_PUBLIC_SIMULATE=true expo start --lan --clear",
    "simulate:ocr": "EXPO_PUBLIC_SIMULATE=true EXPO_PUBLIC_OCR_LIVE=true expo start --lan --clear",
    "forward": "WIN_PATH=$(wslpath -w \"$PWD/scripts/wsl2-expo-forward.ps1\") && powershell.exe -Command \"Start-Process powershell -Verb RunAs -ArgumentList '-ExecutionPolicy Bypass -File \\\"$WIN_PATH\\\"'\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "node node_modules/eslint/bin/eslint.js .",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@react-native-community/netinfo": "11.5.2",
    "@supabase/supabase-js": "^2.103.0",
    "expo": "~55.0.26",
    "expo-constants": "^55.0.13",
    "expo-contacts": "~55.0.14",
    "expo-haptics": "^55.0.14",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.15",
    "expo-print": "^55.0.15",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-sharing": "~55.0.20",
    "expo-sqlite": "~55.0.16",
    "expo-status-bar": "~55.0.6",
    "expo-web-browser": "~55.0.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.3",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "babel-jest": "^29.7.0",
    "eslint": "^10.2.0",
