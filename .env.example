# ── Local development ────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.
#
# EXPO_PUBLIC_* variables are intentionally embedded in the compiled app bundle
# by Metro at build time. SUPABASE_URL and SUPABASE_ANON_KEY are safe to expose
# in the bundle: the anon key is a public JWT designed to be shipped with the
# client (Supabase docs: https://supabase.com/docs/guides/api/api-keys), and
# all data access is enforced by Row Level Security policies in the database.
# No secret keys (Stripe, Tink) are read by the app — they live only in
# Supabase Edge Function secrets (set via `supabase secrets set ...`).
#
# ── EAS Cloud builds ─────────────────────────────────────────────────────────
# For EAS Build (preview / production), set these as EAS secrets so they are
# injected into the build environment without being stored in source control:
#
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_URL   --value https://your-project-ref.supabase.co
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_ANON_KEY --value your-anon-key-here
#
# EAS automatically injects project secrets as env vars at build time.
# A build that runs without these secrets will silently fall back to the
# placeholder values in supabaseClient.ts and fail to connect to Supabase.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Set to "true" to run the app with in-memory mocks (no Supabase, no native modules)
EXPO_PUBLIC_SIMULATE=false

# ── Stripe (Chunk A) — set in Supabase Edge Function secrets, not in the app ──
# supabase secrets set STRIPE_SECRET_KEY=sk_test_...
# supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
#   ^ STRIPE_WEBHOOK_SECRET is printed by the Stripe CLI each time stripe-listen.sh
#     starts. It changes on every run; re-set the secret after each restart.
#
# Webhook endpoint to register in Stripe Dashboard (for production):
#   https://your-project-ref.supabase.co/functions/v1/stripe-webhook
#
# Deploy the Stripe Edge Functions:
#   supabase functions deploy create-payment-link payment-status stripe-webhook
#
# Test webhooks locally (requires Stripe CLI — see scripts/stripe-listen.sh):
#   bash scripts/stripe-listen.sh

# ── Open Banking / Tink (Chunk B) — set in Supabase Edge Function secrets ──
# Register at: https://console.tink.com/
# supabase secrets set TINK_CLIENT_ID=your-client-id
# supabase secrets set TINK_CLIENT_SECRET=your-client-secret
# supabase secrets set TINK_WEBHOOK_SECRET=your-webhook-secret
# supabase secrets set TINK_REDIRECT_URI=ouishare://ob-return
# supabase secrets set TINK_MARKET=FR   # e.g. FR, DE, ES, GB
#
# Webhook endpoint to register in Tink Console:
#   https://your-project-ref.supabase.co/functions/v1/ob-webhook
#
# Deploy all OB Edge Functions:
#   supabase functions deploy ob-initiate ob-status ob-webhook
#
# Run DB migration 004 to add OB columns:
#   supabase db push
